{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reminder",
  "version": "0.3.4",
  "identifier": "com.reminder.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reminder",
        "width": 380,
        "height": 560,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["SimpChinese"],
        "installerIcon": "icons/icon.ico",
        "installerHooks": "windows/hooks.nsh"
      }
    },
    "shortDescription": "轻量级桌面专注提醒",
    "longDescription": "Reminder 是一款轻量级跨平台专注提醒工具，帮助您定时专注、定时休息。"
  }
}
